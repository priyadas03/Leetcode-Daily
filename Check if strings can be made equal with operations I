#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    bool canBeEqual(string s1, string s2) {

        // Even indices: 0, 2
        string a1 = "";
        a1 += s1[0];
        a1 += s1[2];

        string a2 = "";
        a2 += s2[0];
        a2 += s2[2];

        sort(a1.begin(), a1.end());
        sort(a2.begin(), a2.end());

        // Odd indices: 1, 3
        string b1 = "";
        b1 += s1[1];
        b1 += s1[3];

        string b2 = "";
        b2 += s2[1];
        b2 += s2[3];

        sort(b1.begin(), b1.end());
        sort(b2.begin(), b2.end());

        return (a1 == a2) && (b1 == b2);
    }
};
