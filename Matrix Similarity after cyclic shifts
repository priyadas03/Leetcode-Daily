#include <vector>
using namespace std;

class Solution {
public:
    bool areSimilar(vector<vector<int>>& mat, int k) {
        int m = mat.size();
        int n = mat[0].size();
        
        int shift = k % n;  // effective shifts
        
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                
                int new_j;
                
                if (i % 2 == 0) {
                    // even row → left shift
                    new_j = (j + shift) % n;
                } else {
                    // odd row → right shift
                    new_j = (j - shift + n) % n;
                }
                
                if (mat[i][j] != mat[i][new_j]) {
                    return false;
                }
            }
        }
        
        return true;
    }
};
