#include <vector>
using namespace std;

class Solution {
public:
    void solve(int i, vector<int>& candidates, int target, 
               vector<int>& current, vector<vector<int>>& result) {
        
        // Base case
        if (target == 0) {
            result.push_back(current);
            return;
        }

        if (target < 0) return;

        for (int j = i; j < candidates.size(); j++) {
            // Choose
            current.push_back(candidates[j]);

            // Stay at j (reuse allowed)
            solve(j, candidates, target - candidates[j], current, result);

            // Backtrack
            current.pop_back();
        }
    }

    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<vector<int>> result;
        vector<int> current;

        solve(0, candidates, target, current, result);

        return result;
    }
};
