class Solution {
public:
    
    ListNode* reverseKGroup(ListNode* head, int k) {
        ListNode* curr = head;
        
        // Step 1: Check if at least k nodes exist
        int count = 0;
        while(curr && count < k) {
            curr = curr->next;
            count++;
        }
        
        // If less than k nodes → return as it is
        if(count < k) return head;
        
        // Step 2: Reverse first k nodes
        ListNode* prev = NULL;
        curr = head;
        ListNode* next = NULL;
        count = 0;
        
        while(curr && count < k) {
            next = curr->next;
            curr->next = prev;
            prev = curr;
            curr = next;
            count++;
        }
        
        // Step 3: Recursively solve for remaining list
        if(next != NULL) {
            head->next = reverseKGroup(next, k);
        }
        
        // prev is new head of this group
        return prev;
    }
};
